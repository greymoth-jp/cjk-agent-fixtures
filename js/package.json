    "i18n",
    "normalization",
    "grapheme",
    "bidi",
    "east-asian-width",
    "regression",
    "fixtures"
  ],
  "homepage": "https://github.com/greymoth-jp/cjk-agent-fixtures",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/greymoth-jp/cjk-agent-fixtures.git",
    "directory": "js"
  },
  "bugs": "https://github.com/greymoth-jp/cjk-agent-fixtures/issues",
  "author": "greymoth",
  "main": "./index.js",
  "types": "./index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "default": "./index.js"
    },
    "./taxonomy.json": "./taxonomy.json",
    "./package.json": "./package.json"
  },
  "files": [
    "index.js",
    "index.d.ts",
    "src",
    "taxonomy.json",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
